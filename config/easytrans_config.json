      "EASYTRANS_BASE_URL": "https://api.easytransnote.com/v1"
    },
    
    "code_example": {
      "python": "from agent.code_generator import PWACodeGenerator\n\nconfig = {\n    'api_provider': 'easytrans',\n    'api_key': 'your-api-key',\n    'model': 'gemini-2.5-pro'\n}\n\ngenerator = PWACodeGenerator(config)\ncode = generator.generate_fit_code(template_data)"
    },
    
    "full_workflow": {
      "python": "from agent.llm_create_control import LLMCreateCode\n\nagent_config = {\n    'api_provider': 'easytrans',\n    'api_key': 'your-api-key',\n    'model': 'gemini-2.5-pro'\n}\n\nllm_creator = LLMCreateCode(dict_json, agent_config)\nllm_creator.generate_all()"
    }
  },
  
